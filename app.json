{
  "expo": {
    "name": "nutritrack",
    "slug": "nutritrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutritrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "me.laravieira.nutritrack"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/Roboto.ttf"],
          "android": {
            "fonts": [
              {
                "fontFamily": "Roboto",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Roboto-Regular.ttf",
                    "weight": 400,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Roboto-Italic.ttf",
                    "weight": 400,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Roboto-Medium.ttf",
                    "weight": 500,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Roboto-MediumItalic.ttf",
                    "weight": 500,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Roboto-Bold.ttf",
                    "weight": 700,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Roboto-BoldItalic.ttf",
                    "weight": 700,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Roboto-ExtraBold.ttf",
                    "weight": 800,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Roboto-ExtraBoldItalic.ttf",
                    "weight": 800,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Roboto-Black.ttf",
                    "weight": 900,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Roboto-BlackItalic.ttf",
                    "weight": 900,
                    "style": "italic"
                  }
                ]
              }
            ]
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a6ad78e1-1e95-430f-8ffc-4d91f5b1f5b1"
      }
    }
  }
}
